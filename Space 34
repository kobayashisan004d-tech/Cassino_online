<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Cassino Pro</title>

<style>

body{
font-family:Arial;
background:#0f172a;
color:white;
text-align:center;
}

header{
background:#020617;
padding:15px;
font-size:22px;
}

.card{
background:#1e293b;
padding:20px;
margin:20px auto;
border-radius:10px;
max-width:400px;
}

button{
padding:10px;
margin:5px;
background:#22c55e;
border:none;
color:white;
cursor:pointer;
}

input{
padding:10px;
margin:5px;
}

#aviator{
font-size:40px;
margin:10px;
}

.slot{
font-size:40px;
}

</style>

</head>

<body>

<header>🎰 Cassino Pro</header>

<div id="login" class="card">

<h2>Login</h2>

<input id="user" placeholder="Usuário">

<br>

<button onclick="login()">Entrar</button>

</div>

<div id="painel" style="display:none">

<div class="card">

<p>Usuário: <span id="nome"></span></p>
<p>Saldo: R$ <span id="saldo">0</span></p>

</div>

<div class="card">

<h3>Depositar PIX</h3>

<input id="pixValor" placeholder="Valor">

<button onclick="depositar()">Gerar PIX</button>

<div id="pixArea"></div>

</div>

<div class="card">

<h3>🎰 Slot Machine</h3>

<div class="slot" id="slot">🍒 🍋 🍊</div>

<input id="slotBet" placeholder="Aposta">

<br>

<button onclick="girar()">Girar</button>

</div>

<div class="card">

<h3>✈️ Aviator</h3>

<div id="aviator">1.00x</div>

<input id="aviBet" placeholder="Aposta">

<br>

<button onclick="apostar()">Apostar</button>

<button onclick="retirar()">Retirar</button>

</div>

<div class="card">

<h3>🎲 Dado</h3>

<input id="diceBet" placeholder="Aposta">

<button onclick="jogarDado()">Jogar</button>

</div>

</div>

<script>

let banco = JSON.parse(localStorage.getItem("casino")||"{}")
let userAtual
let multi=1
let rodando=false
let aposta=0

function salvar(){

localStorage.setItem("casino",JSON.stringify(banco))

}

function login(){

let u=document.getElementById("user").value

if(!banco[u]){

banco[u]={saldo:0}

}

userAtual=u

document.getElementById("login").style.display="none"
document.getElementById("painel").style.display="block"

document.getElementById("nome").innerText=u

update()

}

function update(){

document.getElementById("saldo").innerText=banco[userAtual].saldo

salvar()

}

function depositar(){

let v=Number(document.getElementById("pixValor").value)

if(!v) return

let codigo="PIX"+Math.floor(Math.random()*999999999)

document.getElementById("pixArea").innerHTML=

`<textarea>${codigo}</textarea>
<p>Pagamento aprovado</p>`

banco[userAtual].saldo+=v

update()

}

function girar(){

let bet=Number(document.getElementById("slotBet").value)

if(bet>banco[userAtual].saldo){

alert("Saldo insuficiente")
return

}

banco[userAtual].saldo-=bet

let frutas=["🍒","🍋","🍊","⭐","💎"]

let a=frutas[Math.floor(Math.random()*5)]
let b=frutas[Math.floor(Math.random()*5)]
let c=frutas[Math.floor(Math.random()*5)]

document.getElementById("slot").innerText=a+" "+b+" "+c

if(a==b && b==c){

let premio=bet*5

alert("Jackpot "+premio)

banco[userAtual].saldo+=premio

}

update()

}

function apostar(){

let v=Number(document.getElementById("aviBet").value)

if(v>banco[userAtual].saldo){

alert("Saldo insuficiente")
return

}

aposta=v

banco[userAtual].saldo-=v

multi=1

rodando=true

loop()

update()

}

function loop(){

if(!rodando) return

multi+=0.05

document.getElementById("aviator").innerText=multi.toFixed(2)+"x"

if(Math.random()<0.02){

rodando=false

alert("💥 Avião caiu")

return

}

setTimeout(loop,100)

}

function retirar(){

if(!rodando) return

rodando=false

let ganho=aposta*multi

alert("Ganhou "+ganho)

banco[userAtual].saldo+=ganho

update()

}

function jogarDado(){

let bet=Number(document.getElementById("diceBet").value)

if(bet>banco[userAtual].saldo){

alert("Saldo insuficiente")
return

}

banco[userAtual].saldo-=bet

let dado=Math.floor(Math.random()*6)+1

alert("Dado: "+dado)

if(dado>=4){

let win=bet*2

banco[userAtual].saldo+=win

alert("Ganhou "+win)

}

update()

}

</script>

</body>
</html>
